# 一度、すべてを無視
*
!*/

# 許可リスト(ホワイトリスト)
!.git/*
!.gitignore
!.gitattributes
!*.js
!*.sh
!*.json
!*.css
!*.toml
!*.yml
!*.yaml
!*.md
!*.txt
!*.csv
!*.svg
!*.png
!*.jpg
!*.jpeg
!*.gif
!*.webp
!*.pdf

# Visual Studio Code
# https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!*.code-workspace

# 除外リスト
node_modules
.obsidian*/graph.json
.obsidian*/workspace*.json